<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Application Confirmation - Kindora</title>
    <style>
      body {
        font-family: 'Inter', sans-serif;
        background-color: #f8f9fc;
        color: #333;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 850px;
        margin: 0 auto;
        background-color: #ffffff;
        padding: 20px;
        text-align: center;
      }
      .header {
        margin-bottom: 20px;
      }
      .header img {
        max-width: 150px;
        height: auto;
      }
      h1 {
        font-size: 24px;
        color: #333;
      }
      p {
        color: #5d5d5d;
        font-size: 14px;
        line-height: 140%;
        font-weight: 500;
        font-style: normal;
        margin: 10px 0;
      }
      c {
        color: #5d5d5d;
        font-size: 12px;
        line-height: 140%;
        font-weight: 500;
        font-style: normal;
        margin: 10px 0;
      }
      footer {
        text-align: center;
        color: grey;
        font-size: 10px;
        line-height: 1.5;
        margin: 10px 0;
        padding-bottom: 10px;
        font-weight: 500;
      }
      .footer {
        margin-top: 20px;
        font-size: 12px;
        color: #888;
      }
      .footer a {
        color: #5764f2;
        text-decoration: none;
      }
    </style>
  </head>
  <body>
    <div class="container">
      {{#if logoUrl}}
      <div class="header">
        <img src="{{logoUrl}}" alt="Kindora" />
      </div>
      {{/if}}

      <h1>Hey {{userName}}</h1>
      <p>
        Thank you for applying to the "{{opportunity}}" opportunity posted by {{organization}}.
        Your application has been received and is being processed.
      </p>

      <p>
        If you did not apply for this opportunity or believe this email was sent to you in error, you can safely ignore it.
      </p>

      <p>Thank you,<br />The Kindora team</p>
      <p>
        Our team is always ready to support. If you need assistance,
        <a href="{{supportUrl}}" style="color: #5764f2; text-decoration: none"
          >Contact us!</a
        >
      </p>

      <div class="footer">
        <c>Copyright &copy; 2025 Kindora.</c><br />
        <footer>Kindora connects volunteers with opportunities to make a difference in their community.</footer>
      </div>
    </div>
  </body>
</html>
